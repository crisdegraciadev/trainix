{
  "name": "express-api-starter-ts",
  "version": "1.2.0",
  "description": " A basic starter for an express.js API with Typescript",
  "main": "src/index.ts",
  "scripts": {
    "start": "cp .env.dev .env && ts-node src/index.ts",
    "dev": "cp .env.dev .env && pnpm prisma:update:dev && nodemon src/index.ts",
    "build": "tsc",
    "lint": "eslint --fix src test",
    "set:env:dev": "cp .env.dev .env",
    "set:env:test": "cp .env.test .env",
    "test:u": "pnpm set:env:test && jest --verbose ./test/unit/*",
    "test:e2e": "pnpm set:env:test && pnpm prisma:update:test && pnpm prisma:seed:test && jest --verbose --maxWorkers=1 ./test/e2e/*",
    "prisma:update:dev": "pnpm set:env:dev && pnpm dlx prisma migrate dev --name init",
    "prisma:update:test": "pnpm set:env:test && pnpm dlx prisma migrate dev --name init",
    "prisma:seed:dev": "pnpm set:env:dev && pnpm dlx prisma db seed",
    "prisma:seed:test": "pnpm set:env:test && pnpm dlx prisma db seed",
    "db:up": "docker-compose -f containers/docker-compose.yml up -d"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "Cristian",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^4.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "effect": "2.0.0-next.23",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.2.5",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "eslint": "^8.42.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier-plugin-prisma": "^4.13.0",
    "prisma": "4.15.0",
    "shx": "^0.3.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
